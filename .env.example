APP_ENV=local
PROCESSING_MODE=local-only

STOP_ON_SECTION_MARKER=true
SECTION_MARKER="NỘI DUNG VỤ ÁN"
MAX_PAGES_BEFORE_CONTENT_MARKER=7
FORCE_FULL_OCR=false
OCR_DPI=300
OCR_DPI_FOR_BLURRY_SCAN=400
EXTRACT_WITHOUT_MARKER=true
FORCE_REPROCESS=false

ENABLE_RED_STAMP_REMOVAL=false
ENABLE_LOCAL_LLM_EXTRACTION=false
ENABLE_CLOUD_LLM_EXTRACTION=false
ENABLE_GLINER=false
ENABLE_LOCAL_LLM_CORRECTION=false

ENABLE_MOCK_OCR=false
ENABLE_MOCK_LOCAL_LLM=false
ENABLE_MOCK_GLINER=false

DEBUG_KEEP_IMAGES=false
DEBUG_SENSITIVE=false
LOG_FULL_TEXT=false
PERSIST_OCR_TEXT_ARTIFACTS=false
PERSIST_SENSITIVE_TEXT_IN_JSON=false

LOCAL_LLM_PROVIDER=vllm
LOCAL_LLM_MODEL_NAME=Qwen/Qwen3-4B-Instruct
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_LLM_MAX_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0
LOCAL_LLM_QUANTIZATION=AWQ

USE_REMOTE_GPU_WORKER=false
GPU_WORKER_BASE_URL=
GPU_WORKER_TOKEN=
GPU_WORKER_TIMEOUT_SECONDS=180
GPU_WORKER_RETRIES=2
GPU_WORKER_FALLBACK=true
GPU_WORKER_FALLBACK_TO_MOCK=false

GLINER_MODEL=urchade/gliner_multi-v2.1
SURYA_LANGS=vi
